# ─── Flutter App Configuration ───────────────────────────────
LOCAL_USERNAME=admin_medihive
LOCAL_PASSWORD=your_secure_password
API_BASE_URL=https://<cloud-run-url>/api
CLOUD_BASE_URL=https://<cloud-run-url>/api
CLINIC_ID=CLI001
APP_VERSION=1.0.0

# ─── Required Backend Environment Variables ──────────────────

# PostgreSQL connection string (Neon, AWS RDS, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Security keys (generate with: python -c "import secrets; print(secrets.token_hex(32))")
# SECRET_KEY=<random-64-char-hex>
# JWT_SECRET_KEY=<random-64-char-hex>

# Enable cloud mode (required for Cloud Run)
# MEDIHIVE_CLOUD=true

# Google Sheets service account JSON (minified, single line)
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# Google Drive OAuth token JSON
# DRIVE_TOKEN_JSON={"token": "...", ...}

# Firebase Admin SDK service account JSON
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Or use legacy FCM server key (fallback if Admin SDK not configured)
# FCM_SERVER_KEY=AAAA...:...

# Google Sheet ID (MediHive - Patient Records)
# GOOGLE_SHEET_ID=1NECj89gjbga45i5ZlwwHU04l107vmKbQGrEJLPQBmpY

# Google Drive Folder ID (MediHive Images)
# DRIVE_ROOT_FOLDER_ID=1Ogx1JHYBBSLTx4glL4-yhcGPLOdBN0GI

# WhatsApp Cloud API (optional)
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=

# Database pool configuration
# DB_POOL_MIN=0
# DB_POOL_MAX=5
# CONNECT_TIMEOUT=10
